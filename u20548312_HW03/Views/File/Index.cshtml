@model IEnumerable<u20548312_HW03.Models.FileModel>

@{
    ViewBag.Title = "Index";
}

<h1>Document FIles</h1>
<h4>Media/ FIles folder</h4>

<table class="table">
    <tr style="background-color:black">
        <th>
            @Html.DisplayNameFor(model => model.FileName)
        </th>
        <th>
            Download Option
        </th>
        <th>
            Delete Option
        </th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FileName)
            </td>
            <td style="align-items:center">
                <button type="button" class=" btn-success">
                    @Html.ActionLink("Download", "DownloadFile", new { fileName = item.FileName })
                </button>
            </td>
            <td style=" align-items:center">
                <button type="button" class="btn-danger">
                    @Html.ActionLink("DELETE", "DeleteFile",
                         new { fileName = item.FileName },
                         new { onclick = "return confirm('Are you sure you wish to delete this?');" })
                </button>
            </td>
        </tr>
    }

</table>
